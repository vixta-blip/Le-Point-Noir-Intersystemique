/* Gabarit exploratoire : perspective appliquée au cadre photographique,
   jamais au livre lui-même. */

.shelf-scene {
  --volume-width: clamp(292px, 23vw, 350px);
  --volume-height: calc(var(--volume-width) * 4 / 3);
  min-height: 540px;
  perspective: 1200px;
}

.shelf-scene::before {
  top: 49%;
  width: min(84%, 390px);
  aspect-ratio: 3 / 4;
  border: 1px solid rgba(255, 250, 248, 0.48);
  border-radius: 26px;
  background: linear-gradient(145deg, rgba(96, 70, 84, 0.92), rgba(133, 104, 120, 0.62));
  box-shadow: 0 32px 70px rgba(45, 30, 36, 0.2);
  transform: translate(-44%, -48%) rotate(3.2deg);
  mix-blend-mode: normal;
  opacity: 0.78;
}

.shelf-light {
  top: -1%;
  left: 58%;
  width: 70%;
  background: radial-gradient(circle, rgba(255, 250, 248, 0.58), transparent 68%);
}

.volume-wall-shadow,
.volume-contact-shadow,
.shelf-board {
  display: none;
}

.volume-select {
  border-radius: 22px;
  transform: perspective(1200px) rotateY(-4.2deg) rotateX(1.4deg) rotateZ(-0.7deg);
  transform-origin: 50% 60%;
  transition: transform 620ms cubic-bezier(0.16, 1, 0.3, 1), filter 620ms ease;
}

.volume-object--render {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 250, 248, 0.72);
  border-radius: 22px;
  background: #d5bec9;
  box-shadow:
    0 28px 55px rgba(45, 30, 36, 0.25),
    0 7px 18px rgba(45, 30, 36, 0.14),
    inset 0 0 0 1px rgba(45, 30, 36, 0.08);
}

.volume-object--render::after {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(112deg, rgba(255, 255, 255, 0.13), transparent 27%, transparent 76%, rgba(38, 25, 31, 0.08));
  pointer-events: none;
  content: "";
}

.volume-render {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.94) contrast(1.025);
  transform: scale(1.002);
  transition: transform 720ms cubic-bezier(0.16, 1, 0.3, 1), filter 720ms ease;
}

.shelf-volume:hover .volume-select,
.shelf-volume:focus-within .volume-select,
.shelf-volume.is-previewed .volume-select {
  transform: perspective(1200px) translate3d(0, -9px, 18px) rotateY(-1.4deg) rotateX(0.5deg) rotateZ(-0.2deg);
}

.shelf-volume:hover .volume-render,
.shelf-volume:focus-within .volume-render,
.shelf-volume.is-previewed .volume-render {
  filter: saturate(0.99) contrast(1.035);
  transform: scale(1.018);
}

.shelf-caption {
  width: min(100%, 420px);
  margin-inline: auto;
}

@media (max-width: 940px) {
  .shelf-scene {
    --volume-width: clamp(300px, 54vw, 360px);
    min-height: 530px;
  }
}

@media (max-width: 680px) {
  .shelf-scene {
    --volume-width: min(83vw, 340px);
    min-height: calc(var(--volume-height) + 48px);
  }

  .shelf-scene::before {
    width: min(78vw, 325px);
    transform: translate(-44%, -48%) rotate(2.5deg);
  }

  .volume-select {
    transform: perspective(1200px) rotateY(-2.8deg) rotateX(0.8deg) rotateZ(-0.45deg);
  }
}

@media (max-width: 390px) {
  .shelf-scene {
    --volume-width: min(82vw, 310px);
  }

  .material-note {
    font-size: 0.68rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .volume-select,
  .volume-render {
    transition: none;
  }
}

/* Contrastes renforcés dans la variante, sans modifier sa palette. */
.orientation-strip details[open] > p,
.section-heading > p {
  color: #66545d;
}

.section-heading .eyebrow-blue {
  color: #674b59;
}

.qr-notice > span[aria-hidden="true"] {
  color: #34272d;
  background: #cbb3c0;
}
